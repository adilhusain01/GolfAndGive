# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# ─── DodoPayments ─────────────────────────────────────────────────────────────
DODO_API_KEY=your-dodo-api-key
# Optional compatibility alias if your deployment already uses Dodo's older key name:
# DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_ENVIRONMENT=test_mode
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret
# Optional compatibility alias if your dashboard/export uses Dodo's older name:
# DODO_PAYMENTS_WEBHOOK_KEY=your-dodo-webhook-secret

# DodoPayments Product IDs (create these in your Dodo dashboard)
DODO_MONTHLY_PRODUCT_ID=prod_monthly_xxx
DODO_YEARLY_PRODUCT_ID=prod_yearly_xxx
DODO_DONATION_PRODUCT_ID=prod_donation_xxx

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Golf & Give"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM="Golf & Give <updates@example.com>"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
